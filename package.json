{
  "name": "chartsignl",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "gen-deploy-deletion": "node scripts/gen-deploy-deletion.js",
    "dev": "turbo run dev",
    "dev:mobile": "turbo run dev --filter=mobile",
    "dev:backend": "turbo run dev --filter=backend",
    "build": "turbo run build",
    "build:web": "turbo run build:web --filter=mobile",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "ensure-mobile-deps": "node scripts/ensure-mobile-node-modules.js",
    "android": "npm run ensure-mobile-deps && expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.2.0",
  "dependencies": {
    "@react-native-community/cli-platform-android": "^20.1.1",
    "@react-native-community/cli-server-api": "^12.3.6",
    "expo": "~51.0.0",
    "expo-asset": "^12.0.12",
    "expo-font": "~11.10.3",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0"
  }
}
