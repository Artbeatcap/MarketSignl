# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (optional — for social content pipeline: POST /api/social/generate)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# Shared secret for /api/social/generate — require header: x-social-key: <value>
SOCIAL_API_SECRET=your-long-random-secret

# Polygon.io Configuration (for market data)
# Get your free API key at https://polygon.io/
POLYGON_API_KEY=your-polygon-api-key

# Massive.com (market data + push price checks) — https://massive.com
MASSIVE_API_KEY=your-massive-api-key

# Push notifications: n8n (or other cron) calls POST /api/notifications/check-prices with header x-cron-secret
# Also gates the prediction resolver endpoints (/api/predictions/resolve, /daily-highlight, /resolver-health)
CRON_SECRET=generate-with-openssl-rand-hex-32
# Enable the in-process prediction resolver on exactly ONE backend instance (runs every 30m)
ENABLE_RESOLVER_CRON=true

# n8n workflow automation
# Required in production. Generate once and keep stable, for example:
# openssl rand -hex 32
N8N_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
# Protect the n8n admin UI in nginx with Basic Auth:
# htpasswd -c /etc/nginx/.htpasswd-n8n admin
# Store OpenAI/Anthropic/Polygon keys as n8n credentials or variables instead of container env vars.
# Rotate those provider keys if they were ever exposed through a public or unclaimed n8n instance.

# Server Configuration
PORT=4000
NODE_ENV=development

# CORS - allowed origins (comma separated)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Optional: Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Email (SMTP) - for account deletion confirmation
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=ChartSignl <noreply@chartsignl.com>

# Frontend / API URLs (for deletion links and CORS)
FRONTEND_URL=https://chartsignl.com
API_URL=https://api.chartsignl.com

# Weekly Brief email (SendGrid + artifact ingest from Options Plunge)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
WEEKLY_CONTENT_INGEST_SECRET=generate-with-openssl-rand-hex-32
WEEKLY_BRIEF_FROM="ChartSignl <weekly@chartsignl.com>"
# Optional: Slack/Discord webhook for skip/failure alerts
ALERT_WEBHOOK_URL=

# Stripe (web subscriptions)
# Dashboard: https://dashboard.stripe.com/ (toggle Test/Live mode in the UI)
STRIPE_SECRET_KEY=sk_your-secret-key
# Developers → Webhooks → [your endpoint] → Reveal signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Live price ID (used when STRIPE_SECRET_KEY is sk_live_...)
STRIPE_PRICE_ID=price_your_live_price_id
# Test price ID (used when STRIPE_SECRET_KEY is sk_test_...); get from Dashboard in Test mode
STRIPE_PRICE_ID_TEST=price_your_test_price_id
