    "d3-shape": "^3.2.0",
    "expo": "~52.0.0",
    "expo-auth-session": "~6.0.3",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-dev-client": "~5.0.20",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.22",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.24",
