{
  "expo": {
    "name": "MarketSignl",
    "slug": "marketsignl",
    "version": "1.1.2",
    "sdkVersion": "54.0.0",
    "scheme": "marketsignl",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./apps/mobile/assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.optionsplungellc.marketsignl",
      "associatedDomains": [
        "applinks:marketsignl.com"
      ],
      "icon": "./apps/mobile/assets/icon.png"
    },
    "android": {
      "package": "com.optionsplungellc.marketsignl",
      "permissions": [
        "com.android.vending.BILLING"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./apps/mobile/assets/adaptive-icon.png",
        "backgroundColor": "#F0F9F9"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "marketsignl",
              "host": "auth",
              "pathPrefix": "/reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "extra": {
      "eas": {
        "projectId": "6d633a95-d09f-43c6-959f-20879ad24a44"
      }
    }
  }
}
